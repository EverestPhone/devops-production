{
  "title": "DevOps API Monitoring",
  "panels": [
    {
      "type": "stat",
      "title": "Total Requests",
      "targets": [
        {
          "expr": "app_requests_total"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Request Rate",
      "targets": [
        {
          "expr": "rate(app_requests_total[1m])"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 }
    },
    {
      "type": "stat",
      "title": "Service Status",
      "targets": [
        {
          "expr": "up"
        }
      ],
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 }
    }
  ],
  "schemaVersion": 36,
  "version": 1
}